---
import Base from '@/layouts/Base.astro'

function snakecaseToTitleCase(str: string) {
    return str
        .split('_')
        .map(word => word.charAt(0).toUpperCase() + word.slice(1))
        .join(' ')
}

const memberPictures: { default: { src: string } }[] = await Promise.all(
    Object.entries(import.meta.glob<{ default: ImageMetadata }>('@/assets/team/*')).map(([_name, picture]) =>
        picture(),
    ),
)

const nameOverrides: Record<string, { firstName: string; lastName: string }> = {
    davide_pio_lomonaco: { firstName: 'Davide Pio', lastName: 'Lomonaco' },
}

const extractFileName = (src: string) => src.split('/').at(-1)!.split('?')[0].split('.')[0]

const parseNameParts = (fileName: string): { firstName: string; lastName: string } => {
    if (nameOverrides[fileName]) {
        return nameOverrides[fileName]
    }

    const nameParts = snakecaseToTitleCase(fileName).split(' ')
    return {
        firstName: nameParts.at(0)!,
        lastName: nameParts.slice(1).join(' '),
    }
}

const teamMembers = memberPictures
    .map(picture => {
        const fileName = extractFileName(picture.default.src)
        const { firstName, lastName } = parseNameParts(fileName)

        return {
            fullName: snakecaseToTitleCase(fileName),
            firstName,
            lastName,
            picture,
        }
    })
    .toSorted((a, b) => a.lastName.localeCompare(b.lastName))
---

<Base>
    <section id="team">
        <div class="people-list">
            <div class="wide">
                <h1>Team</h1>
            </div>
            {
                teamMembers.map(member => (
                    <div class="person">
                        <div class="picture">
                            <img src={member.picture.default.src} alt={`Picture of ${member.fullName}`} />
                        </div>
                        <h3>{member.firstName}</h3>
                        <h3>{member.lastName}</h3>
                    </div>
                ))
            }
        </div>
    </section>
</Base>
