---
import Base from '@/layouts/Base.astro'
import { Icon } from 'astro-icon/components'

import gdeBannerImage from '@/assets/gde-banner.png'
import wtmLogo from '@/assets/logo_wtm_quadrato_2026_notitle.png'
import googlerBanner from '@/assets/banner-googler.svg'

import { TALKS } from '@/lib/astro/sessionize'

function uniqueBy<T, S>(array: T[], key: (item: T) => S): T[] {
    const seen = new Set<S>()
    return array.filter(item => {
        const k = key(item)
        if (seen.has(k)) {
            return false
        }
        seen.add(k)
        return true
    })
}
---

<Base>
    <section class="wide">
        <div class="people-list">
            <div class="wide">
                <h1>Speakers</h1>
            </div>
            {
                // finally we deduplicate all the speakers giving priority to
                // the talks when the speaker is the main speaker
                uniqueBy(
                    [
                        // first add the main speaker of each talk
                        ...TALKS.map(talk => ({
                            talk,
                            speaker: talk.speakers[0],
                        })),
                        // then add the other speakers of each talk
                        ...TALKS.flatMap(talk =>
                            talk.speakers.slice(1).map(speaker => ({
                                talk,
                                speaker,
                            })),
                        ),
                    ].sort((a, b) => a.speaker.lastName.localeCompare(b.speaker.lastName)),
                    ({ speaker }) => speaker.id,
                ).map(({ talk, speaker }) => (
                    <a class="person interactive" href={`/talk/${talk.id}`}>
                        <div class="picture">
                            <img src={speaker.profilePicture} alt={speaker.firstName + ' ' + speaker.lastName} />
                            <div class="picture-chips-stack">
                                {speaker.isWtmAmbassador && (
                                    <div class="picture-chip">
                                        <img src={wtmLogo.src} />
                                        <span>Ambassador</span>
                                    </div>
                                )}
                                {speaker.isGDE && (
                                    <div class="picture-chip">
                                        <img src={gdeBannerImage.src} />
                                    </div>
                                )}
                                {speaker.isGoogler && (
                                    <div class="picture-chip">
                                        <img style={{ transform: 'translateY(2px)' }} src={googlerBanner.src} />
                                    </div>
                                )}
                            </div>
                        </div>

                        <h3>{speaker.firstName}</h3>
                        <h3>{speaker.lastName}</h3>

                        <p>{talk.title}</p>
                    </a>
                ))
            }
        </div>
    </section>
</Base>
