---
import { parseGridSpan, type GridSpan } from '@/lib/astro/image-utils'
import { resolveImageModules } from '@/lib/astro/server-utils'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { join } from 'path'
import sharp from 'sharp'

// Import gallery images with eager loading
const galleryGlob = import.meta.glob<{ default: ImageMetadata }>('@/assets/gallery/*.jpg', {
    eager: true,
})

// Get the project source directory
const projectRoot = process.cwd()
const srcDir = join(projectRoot, 'src')

// Process images to include grid span and LQIP
interface ProcessedImage {
    meta: ImageMetadata
    span: GridSpan
    lqip: string
}

const images: ProcessedImage[] = await Promise.all(
    Object.entries(galleryGlob).map(async ([path, module]) => {
        const meta = module.default

        // Convert glob path to filesystem path
        // Glob paths from @/assets/gallery/*.jpg look like: '../../assets/gallery/picture-01@1x2.jpg'
        // Extract just the filename from the path
        const filename = path.split('/').pop() || ''
        const fsPath = join(srcDir, 'assets', 'gallery', filename)

        const span = parseGridSpan(meta.src)
        // Generates a 16x16px Low-Quality Image Placeholder (LQIP) as a webp base64-encoded data URI.
        const base64Data = (
            await sharp(fsPath).blur(100).resize(16).blur(0.58).webp({ quality: 10 }).toBuffer()
        ).toString('base64')
        const lqip = `data:image/webp;base64,${base64Data}`

        return { meta, span, lqip }
    }),
)

// Calculate total grid columns for mobile animation
const totalCols = images.reduce((acc, { span }) => acc + span.cols, 0)
---

<!-- Static Photo Gallery Grid (desktop only) -->
<section id="gallery" class="tight">
    <div class="image-gallery">
        <div class="image-gallery-wrapper">
            {
                images.slice(0, 10).map(({ meta, span, lqip }, i) => {
                    return (
                        <Image
                            src={meta}
                            format="webp"
                            quality={60}
                            width={800}
                            loading="lazy"
                            decoding="async"
                            alt={`gallery image ${i}`}
                            style={`--rows: ${span.rows};
                                --cols: ${span.cols};
                                background-image: url('${lqip}');
                                background-size: cover; 
                                background-position: center;`}
                        />
                    )
                })
            }
        </div>
    </div>
</section>

<!-- Animated Photo Gallery (mobile only) -->
<section class="photoContainer">
    {
        [0, 1].map(() => {
            const rowImages = [...images, ...images.slice(0, 5)]

            return (
                <div class="track" style={{ '--total-boxes': totalCols }}>
                    {rowImages.map(({ meta, span, lqip }, i) => {
                        const imgRatio = meta.height / meta.width

                        return (
                            <div
                                class="box card hfix"
                                style={{
                                    '--colspan': `${span.cols}`,
                                    '--imgRatio': `${imgRatio}`,
                                    'backgroundImage': `url(${lqip})`,
                                }}
                            >
                                <Image
                                    src={meta}
                                    format="webp"
                                    quality={40}
                                    width={640}
                                    loading="lazy"
                                    decoding="async"
                                    alt={`Gallery image ${i}`}
                                    class="boxImage"
                                />
                            </div>
                        )
                    })}
                </div>
            )
        })
    }
</section>
